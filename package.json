{
  "name": "productionos",
  "version": "1.0.0-beta.1",
  "description": "ProductionOS — AI engineering OS for Claude Code. 76 agents, 39 commands, 12 hooks. Smart routing + adaptive learning + dynamic agent factory.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "productionos": "bin/install.cjs"
  },
  "files": [
    "bin/",
    ".claude/commands/",
    ".claude/skills/",
    "agents/",
    "VERSION",
    "CLAUDE.md"
  ],
  "scripts": {
    "build": "bun run gen:skill-docs",
    "gen:skill-docs": "bun run scripts/gen-skill-docs.ts",
    "skill:check": "bun run scripts/skill-check.ts",
    "test": "bun test tests/",
    "test:unit": "bun test tests/agent-index.test.ts tests/command-validation.test.ts tests/convergence-unit.test.ts tests/file-ownership.test.ts tests/skill-activation.test.ts tests/skill-validation.test.ts tests/stack-detector.test.ts tests/wave-state.test.ts tests/textgrad.test.ts",
    "test:integration": "bun test tests/agent-execution.test.ts tests/convergence.test.ts tests/deep-eval.test.ts tests/e2e-hooks.test.ts tests/hooks.test.ts tests/integration.test.ts tests/worktree.test.ts tests/worktree-integration.test.ts tests/swarm-scope-integration.test.ts tests/broadcast.test.ts",
    "test:e2e": "bun test tests/behavioral.test.ts tests/behavioral.commands.test.ts tests/hook-contracts.test.ts",
    "bench:scope": "bun run scripts/bench-scope-enforcement.ts",
    "validate": "bun run scripts/validate-agents.ts",
    "audit:context": "bun run scripts/context-audit.ts",
    "dashboard": "bun run scripts/review-dashboard.ts show",
    "dashboard:log": "bun run scripts/review-dashboard.ts log",
    "dashboard:clear": "bun run scripts/review-dashboard.ts clear",
    "eval": "bun run scripts/eval-runner.ts",
    "integration:run": "bun run scripts/integration-test.ts",
    "integration:mock": "bun run scripts/integration-test.ts --mock-only",
    "integration:validate": "bun run scripts/integration-test.ts --validate-only",
    "integration:contracts": "bun run scripts/integration-test.ts --contracts",
    "worktree:create": "bun run scripts/worktree-manager.ts create",
    "worktree:list": "bun run scripts/worktree-manager.ts list",
    "worktree:status": "bun run scripts/worktree-manager.ts status",
    "worktree:merge": "bun run scripts/worktree-manager.ts merge",
    "worktree:cleanup": "bun run scripts/worktree-manager.ts cleanup",
    "worktree:preflight": "bun run scripts/worktree-manager.ts preflight",
    "worktree:assign": "bun run scripts/worktree-manager.ts assign",
    "stats": "bun run scripts/stats-dashboard.ts",
    "eval:gate": "bash hooks/pre-push-gate.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "productionos",
    "claude-code",
    "claude-code-plugin",
    "agentic-dev",
    "llm-judge",
    "auto-swarm",
    "recursive-improvement",
    "multi-agent"
  ],
  "author": {
    "name": "ProductionOS Contributors",
    "url": "https://github.com/ShaheerKhawaja/ProductionOS"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ShaheerKhawaja/ProductionOS.git"
  },
  "homepage": "https://github.com/ShaheerKhawaja/ProductionOS",
  "devDependencies": {
    "bun-types": "^1.3.0",
    "markdownlint-cli": "^0.48.0",
    "typescript": "^5.9.3"
  }
}
