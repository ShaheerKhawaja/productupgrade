{
  "_meta": "ProductionOS v1.0.0-beta.1 — 76 agents | 39 commands | 12 hooks | 4-layer Production House | scope enforcement",
  "SessionStart": [
    {
      "matcher": "startup|resume|clear|compact",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.sh\"",
          "async": false
        }
      ]
    }
  ],
  "PreToolUse": [
    {
      "matcher": "Edit|Write|Bash|NotebookEdit|mcp__filesystem__write_file|mcp__filesystem__edit_file|mcp__filesystem__move_file",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scope-enforcement.sh\"",
          "statusMessage": "ProductionOS: Scope check..."
        }
      ]
    },
    {
      "matcher": "Edit|Write|Bash",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/repo-boundary-guard.sh\"",
          "statusMessage": "ProductionOS: Repo boundary..."
        },
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/protected-file-guard.sh\"",
          "statusMessage": "ProductionOS: File guard..."
        },
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-edit-security.sh\"",
          "statusMessage": "ProductionOS: Security scan..."
        }
      ]
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-commit-gitleaks.sh\"",
          "statusMessage": "ProductionOS: Secret scan..."
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Edit|Write",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/self-learn.sh\"",
          "async": true
        },
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-telemetry.sh\"",
          "async": true
        },
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/post-edit-review-hint.sh\"",
          "async": true
        }
      ]
    },
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/post-bash-telemetry.sh\"",
          "async": true
        }
      ]
    }
  ],
  "Stop": [
    {
      "matcher": "",
      "hooks": [
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/stop-session-handoff.sh\"",
          "async": true
        },
        {
          "type": "command",
          "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/stop-extract-instincts.sh\"",
          "async": true
        }
      ]
    }
  ]
}
