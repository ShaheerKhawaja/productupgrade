#!/usr/bin/env bash
# ProductionOS — analytics dashboard
set -euo pipefail
STATE_DIR="${PRODUCTIONOS_HOME:-$HOME/.productionos}"
ANALYTICS="$STATE_DIR/analytics"

# Try Ink dashboard first, fallback to plain text
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "$0")/.." && pwd)}"
INK_DASH="$PLUGIN_ROOT/scripts/ui/analytics-dashboard.tsx"
# Only use Ink when stdout is a real TTY (not piped/captured by tests)
if command -v bun >/dev/null 2>&1 && [ -f "$INK_DASH" ] && [ -t 1 ]; then
  PRODUCTIONOS_HOME="$STATE_DIR" bun run "$INK_DASH" 2>/dev/null && exit 0
fi

# Fallback: plain text dashboard
echo "ProductionOS Analytics"
echo "━━━━━━━━━━━━━━━━━━━━━"

if [ -f "$ANALYTICS/skill-usage.jsonl" ]; then
  TOTAL=$(wc -l < "$ANALYTICS/skill-usage.jsonl" | tr -d ' ')
  echo "  Total events: $TOTAL"
  echo "  Top skills:"
  python3 -c "
import json, collections
counts = collections.Counter()
import sys; analytics_path = sys.argv[1] if len(sys.argv) > 1 else '$ANALYTICS/skill-usage.jsonl'
for line in open(analytics_path):
    try:
        d = json.loads(line)
        counts[d.get('skill', d.get('event',''))] += 1
    except: pass
for skill, count in counts.most_common(10):
    print(f'    {skill}: {count}')
" "$ANALYTICS/skill-usage.jsonl" 2>/dev/null || echo "    (no data yet)"
else
  echo "  No analytics data yet."
fi

echo ""
SESSIONS=$(find "$STATE_DIR/sessions" -mmin -120 -type f 2>/dev/null | wc -l | tr -d ' ')
echo "  Active sessions (last 2h): $SESSIONS"

if [ -f "$ANALYTICS/review-log.jsonl" ]; then
  REVIEWS=$(wc -l < "$ANALYTICS/review-log.jsonl" | tr -d ' ')
  echo "  Reviews logged: $REVIEWS"
else
  echo "  Reviews logged: 0"
fi
