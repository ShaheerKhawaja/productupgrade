#!/usr/bin/env bash
# pos-timeline-log — append skill execution event to project timeline
set -euo pipefail

STATE_DIR="${PRODUCTIONOS_HOME:-$HOME/.productionos}"
PROJECT_SLUG=$(basename "$(git rev-parse --show-toplevel 2>/dev/null)" 2>/dev/null || basename "$PWD")
TIMELINE_DIR="$STATE_DIR/timeline"
TIMELINE_FILE="$TIMELINE_DIR/$PROJECT_SLUG.jsonl"

mkdir -p "$TIMELINE_DIR"

INPUT="${1:-}"
if [ -z "$INPUT" ]; then
  echo "Usage: pos-timeline-log '{\"skill\":\"...\",\"event\":\"started|completed|failed\"}'" >&2
  exit 1
fi

# Add timestamp and session info
ENTRY=$(python3 -c "
import json, sys, os
from datetime import datetime, timezone
d = json.loads(sys.argv[1])
d['ts'] = datetime.now(timezone.utc).strftime('%Y-%m-%dT%H:%M:%SZ')
d['session'] = f'{os.getpid()}-{os.getppid()}'
print(json.dumps(d, separators=(',', ':')))
" "$INPUT" 2>/dev/null) || exit 0

echo "$ENTRY" >> "$TIMELINE_FILE"
